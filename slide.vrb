                    fake2/.style={rectangle, fill=blue!20, draw=blue!60!black, minimum size=0.6cm, inner sep=0pt},
                    domainbox/.style={ellipse, draw=gray, dashed, thick, minimum width=3cm, minimum height=2cm},
                    arrow/.style={-stealth, thick, color=gray}
                ]
